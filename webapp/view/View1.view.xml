<mvc:View
    controllerName="zov001.controller.View1"
    xmlns:t="sap.ui.table"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns="sap.m"
    height="100%">

<!-- title="{i18n>pagTitle}"  -->
    <Page id="pageMain"
        title="{
            parts:[
                {path:'i18n>welcomeMsg'},
                {path:'/usuario/nome'}
            ],
            formatter: '.formatWelcomeMessage'
        }"
        enableScrolling="true"
        class="sapUiContentPadding">

        <content>

            <VBox id="vBoxCustomer" class="sapUISTinyMargen">
                <Button id ="buttonNewCustomer" text="Novo Cliente" press="onNewCustomer"/>
                <Button id ="buttonEditCustomer1" text="Editar Cliente 1" press="onEditCustomer1"/>
            </VBox>

        </content>

    </Page>

</mvc:View>