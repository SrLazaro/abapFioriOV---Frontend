<mvc:View
    controllerName="zov001.controller.View1"
    xmlns:t="sap.ui.table"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns="sap.m"
    height="100%">

<!-- title="{i18n>pagTitle}"  -->
    <Page id="pageMain"
        title="{
            parts:[
                {path:'i18n>welcomeMsg'},
                {path:'/usuario/nome'}
            ],
            formatter: '.formatWelcomeMessage'
        }"
        enableScrolling="true"
        class="sapUiContentPadding">

        <content>

            <VBox id="vBoxOV" class="sapUISTinyMargen">
                
                <Label id="label001" text="Última OV Criada"/>
                <Input id="lastOrdemId" editable="false"/>
                
                <TextArea id="textArea001" value="" rows="8" width="100%" editable="false"/>
            </VBox>

            <HBox id="hBoxOV" class="sapUISTinyMargen">

                <Button id="butttonCreateOV" text="Criar OV" press="onCreateOVCab"/>
                <Button id="butttonCreateDeepOV" text="Criar OV (Deep)" press="onCreateDeepOVCab"/>
                <Button id="butttonReadOV" text="Ler OV" press="onReadOVCab"/>
                <Button id="butttonUpdateOV" text="Atualizar OV" press="onUpdateOVCab"/>
                <Button id="butttonDeleteOV" text="Deletar OV" press="onDeleteOVCab"/>
        
            </HBox>

        </content>

    </Page>

</mvc:View>